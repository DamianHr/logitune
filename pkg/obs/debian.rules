#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_configure:
	cmake -B build -G Ninja -DCMAKE_INSTALL_PREFIX=/usr -DCMAKE_BUILD_TYPE=Release -DBUILD_TESTING=OFF -Wno-dev

override_dh_auto_build:
	cmake --build build -j$$(nproc)

override_dh_auto_test:
	# Tests require hardware (hidraw) — skip in package build

override_dh_auto_install:
	DESTDIR=$(CURDIR)/debian/logitune cmake --install build
